    "@types/react-dom": "^19.2.3",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.553.0",
    "next": "^16.0.10",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hook-form": "^7.53.1",
    "recharts": "^3.4.1",
    "socket.io-client": "^4.8.1",
